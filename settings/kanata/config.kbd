;; select device
(defcfg
  linux-dev-names-include (
    "  2.4G Wireless Device Keyboard"
    "  2.4G Wireless Device"
  )
)

;; define source
(defsrc
  caps esc grv
  lalt lctrl lmet
  ralt
  h j k l
  n m , .
)

;; define aliases
(defalias
  vim-layer (layer-toggle vim)
)

;; define layers
(deflayer default
  esc grv caps
  lctl lmet lalt
  @vim-layer
  h j k l
  n m , .
)
(deflayer vim
  _ _ _
  _ _ _
  _
  left down up right
  home pgdn pgup end
)
