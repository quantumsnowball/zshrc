;; Only select the keyboard device
(defcfg
  linux-dev-names-include (
    "  2.4G Wireless Device Keyboard"
    "  2.4G Wireless Device"
  )
)

(defsrc
  caps  esc   grv   lalt  lctrl  lmet  ralt  h  j  k  l
)

(defalias
  vim-layer (layer-toggle vim)
)

(deflayer default
  esc   grv   caps  lctl  lmet   lalt  @vim-layer  h    j    k   l
)

(deflayer vim
  _     _     _     _     _      _     _         left down up  right
)
